<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wps.yundoc.businesssystem.infrastructure.BizSystemApiPermissionMapper">

    <resultMap id="BizSystemApiPermissionResultMap"
               type="com.wps.yundoc.businesssystem.infrastructure.BizSystemApiPermissionPO">
        <id property="businessSystemId" column="business_system_id"/>
        <id property="apiCode" column="api_code"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BizSystemApiPermissionColumns">
        business_system_id,
        api_code,
        status,
        created_at,
        updated_at
    </sql>

    <select id="selectByBusinessSystemIdAndApiCode" resultMap="BizSystemApiPermissionResultMap">
        SELECT
        <include refid="BizSystemApiPermissionColumns"/>
        FROM biz_system_api_permission
        WHERE business_system_id = #{businessSystemId}
          AND api_code = #{apiCode}
    </select>

    <select id="selectByBusinessSystemId" resultMap="BizSystemApiPermissionResultMap">
        SELECT
        <include refid="BizSystemApiPermissionColumns"/>
        FROM biz_system_api_permission
        WHERE business_system_id = #{businessSystemId}
        ORDER BY api_code ASC
    </select>
</mapper>
