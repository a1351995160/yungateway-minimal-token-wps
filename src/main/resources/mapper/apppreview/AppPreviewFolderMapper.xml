<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wps.yundoc.capability.apppreview.infrastructure.AppPreviewFolderMapper">

    <resultMap id="AppPreviewFolderResultMap"
               type="com.wps.yundoc.capability.apppreview.infrastructure.AppPreviewFolderPO">
        <id property="businessSystemId" column="business_system_id"/>
        <id property="driveId" column="drive_id"/>
        <result property="folderId" column="folder_id"/>
        <result property="folderName" column="folder_name"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="AppPreviewFolderColumns">
        business_system_id,
        drive_id,
        folder_id,
        folder_name,
        created_at,
        updated_at
    </sql>

    <select id="selectByBusinessSystemIdAndDriveId" resultMap="AppPreviewFolderResultMap">
        SELECT
        <include refid="AppPreviewFolderColumns"/>
        FROM app_preview_folder
        WHERE business_system_id = #{businessSystemId}
          AND drive_id = #{driveId}
    </select>

    <insert id="upsert">
        INSERT INTO app_preview_folder (
            business_system_id,
            drive_id,
            folder_id,
            folder_name,
            created_at,
            updated_at
        ) VALUES (
            #{businessSystemId},
            #{driveId},
            #{folderId},
            #{folderName},
            NOW(3),
            NOW(3)
        )
        ON DUPLICATE KEY UPDATE
            folder_id = VALUES(folder_id),
            folder_name = VALUES(folder_name),
            updated_at = NOW(3)
    </insert>
</mapper>
